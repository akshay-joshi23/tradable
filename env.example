# ── Mobile (EXPO_PUBLIC_* is bundled into the app) ───────────────────────────
EXPO_PUBLIC_API_BASE_URL=http://10.x.x.x:3000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
EXPO_PUBLIC_GOOGLE_AUTH_WEB_CLIENT_ID=

# Cal.com — event type ID from cal.com/event-types, timezone for slot display
EXPO_PUBLIC_CAL_EVENT_TYPE_ID=your-event-type-id
EXPO_PUBLIC_BOOKING_TIMEZONE=America/New_York

# ── Backend only (never put these in EXPO_PUBLIC_*) ───────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
CAL_API_KEY=your-cal-api-key
